	<SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF"/>

	<SolidColorBrush x:Key="PrimaryAccentBrush" Color="#3B82F6"/>
	<SolidColorBrush x:Key="PrimaryAccentHoverBrush" Color="#2563EB"/>

	<SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827"/>
