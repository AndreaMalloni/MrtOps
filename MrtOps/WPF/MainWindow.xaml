<Window x:Class="MrtOps.Presentation.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MrtOps.Presentation.WPF.Views"
        xmlns:viewmodels="clr-namespace:MrtOps.Presentation.WPF.ViewModels"
        Title="MrtOps - Report Lifecycle Management" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Presentation/WPF/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:BatchProcessingViewModel}">
                <views:BatchProcessingView />
            </DataTemplate>

            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}" x:Key="NavBtnStyle">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CurrentSection}" Value="Batch">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="380" MinWidth="250" MaxWidth="600"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                        <Border Width="24" Height="24" Background="{DynamicResource PrimaryAccentBrush}" CornerRadius="4" Margin="0,0,12,0"/>
                        <TextBlock Text="MrtOps" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,10">
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Dashboard" Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Scaffolding" Command="{Binding NavigateCommand}" CommandParameter="Scaffolding"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Batch Processing" Command="{Binding NavigateCommand}" CommandParameter="Batch"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Database Scanner" Command="{Binding NavigateCommand}" CommandParameter="Scanner"/>
                    </StackPanel>

                    <Button Grid.Row="2" Style="{StaticResource SidebarButtonStyle}" Content="Toggle Theme" Command="{Binding ToggleThemeCommand}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Background="{DynamicResource WindowBgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Undo / Rollback" Padding="15,8"/>
                    </StackPanel>
                </Border>

                <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>
            </Grid>

            <GridSplitter Grid.Column="2" Width="5" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>

            <Border Grid.Column="3" Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Padding="25">
                <StackPanel>
                    <Grid Margin="0,0,0,30">
                        <TextBlock Text="Report Preview Area" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="›" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                    </Grid>
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="25" Effect="{StaticResource ModernShadow}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Financial Report" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Q1 2026 Summary" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,20"/>

                            <Border Background="{DynamicResource BorderBrush}" Height="2" CornerRadius="1" Margin="0,0,0,15"/>
                            <Border Background="{DynamicResource BorderBrush}" Height="10" CornerRadius="5" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource BorderBrush}" Height="10" CornerRadius="5" Width="180" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource ConsoleBgBrush}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="CONSOLE OUTPUT" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,0,10"/>

                <TextBox Grid.Row="1" Text="{Binding ConsoleOutput}" 
                         Foreground="{DynamicResource ConsoleTextBrush}" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         FontFamily="Consolas" 
                         FontSize="13"
                         IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" 
                         TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>